[user]
    name = "Joel Koch"
    useConfigOnly = true

[init]
    defaultbranch = main

[alias]
    personal = "config user.email 'joel@joelkoch.dev'"
    work = "config user.email 'joel@bitcrowd.net'"

[submodule]
    recurse = true

[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
